# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# screenshots & visual diffs
/screenshots/
/screenshots-atf/
/screenshots-matched/
/diffs/
/tmp/

# design mockups (large binary files)
/设计稿/
设计稿.zip
*.zip

# claude session files
/.claude/

# local SQLite database (seeded at runtime)
/data/*.db
/data/*.db-shm
/data/*.db-wal

# temp artifacts & debug captures
*.b64
dev-server*.log
/diff-report*.json
/screenshot_*.png
/blog_full_mockup.png
