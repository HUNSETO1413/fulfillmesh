# PostgreSQL connection string. With docker compose this points at the `db`
# service; for local dev point it at your own Postgres instance.
DATABASE_URL=postgres://fulfillmesh:fulfillmesh@localhost:5432/fulfillmesh

# Secret used to sign session cookies (HMAC-SHA256). Set a long random value in production.
AUTH_SECRET=change-me-to-a-long-random-string

# Public base URL used for canonical links, sitemap and Open Graph tags.
NEXT_PUBLIC_SITE_URL=https://fulfillmesh.com
